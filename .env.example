# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dlbot_db
DB_USER=dlbot_user
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Pyrogram (for large file uploads)
PYROGRAM_APP_ID=your_app_id_here
PYROGRAM_APP_HASH=your_app_hash_here

# Web Panel
ADMIN_WEB_PASSWORD=your_web_password_here

# Payment Gateways
CRYPTOBOT_TOKEN=your_cryptobot_token_here
NOWPAYMENTS_API_KEY=your_nowpayments_key_here
ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id_here

# Optional Settings
LOG_LEVEL=INFO
DEBUG=False
