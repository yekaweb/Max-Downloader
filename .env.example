# ============================================================================
# TELEGRAM BOT CONFIG
# ============================================================================
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_IDS=123456789,987654321
BOT_USERNAME=your_bot_username

# ============================================================================
# DATABASE CONFIG
# ============================================================================
# For local development you can use SQLite
DB_TYPE=sqlite
DB_PATH=./dlbot.db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=dlbot_production

# ============================================================================
# REDIS CONFIG (optional)
# ============================================================================
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=
#REDIS_DECODE_RESPONSES=true

# ============================================================================
# PYROGRAM CONFIG (for large file uploads up to 4GB)
# ============================================================================
PYROGRAM_APP_ID=YOUR_API_ID
PYROGRAM_APP_HASH=YOUR_API_HASH
PYROGRAM_SESSION_NAME=your_session_name

# ============================================================================
# CELERY CONFIG (optional)
# ============================================================================
#CELERY_BROKER_URL=redis://localhost:6379/0
#CELERY_RESULT_BACKEND=redis://localhost:6379/1
#CELERY_TASK_TIME_LIMIT=3600

# ============================================================================
# PAYMENT CONFIG
# ============================================================================
CRYPTOBOT_API_TOKEN=YOUR_CRYPTOBOT_TOKEN_HERE
ZARINPAL_MERCHANT_ID=YOUR_ZARINPAL_MERCHANT_ID

# ============================================================================
# LOCALIZATION
# ============================================================================
DEFAULT_LANGUAGE=fa
SUPPORTED_LANGUAGES=fa,en,ar,ru,zh

# ============================================================================
# FILE STORAGE CONFIG
# ============================================================================
TEMP_DOWNLOAD_DIR=./temp_downloads
CACHE_FILE_DIR=./cached_files
MAX_FILE_SIZE=4294967296
MAX_FILE_AGE_HOURS=48

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_REFERRAL_SYSTEM=true
ENABLE_FORCE_JOIN=true
ENABLE_BROADCAST=true
ENABLE_ADMIN_PANEL=true

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/dlbot.log
LOG_FORMAT=json

# ============================================================================
# APP SETTINGS
# ============================================================================
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
WORKER_COUNT=2

# ============================================================================
# WEB PANEL (FastAPI)
# ============================================================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
# ============================================================================
# TELEGRAM BOT CONFIG
# ============================================================================
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_IDS=123456789,987654321
BOT_USERNAME=dlbot

# ============================================================================
# DATABASE CONFIG
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=dlbot_user
DB_PASSWORD=secure_password_here
DB_NAME=dlbot_db

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ============================================================================
# REDIS CONFIG
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=true

# Cache TTL (seconds)
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# ============================================================================
# PYROGRAM CONFIG (for large file uploads up to 4GB)
# ============================================================================
PYROGRAM_APP_ID=YOUR_APP_ID_HERE
PYROGRAM_APP_HASH=YOUR_APP_HASH_HERE
PYROGRAM_SESSION_NAME=dlbot_session

# ============================================================================
# CELERY CONFIG (for async task queue)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=3600

# ============================================================================
# PAYMENT CONFIG
# ============================================================================
# CryptoBot (Telegram native crypto)
CRYPTOBOT_API_TOKEN=YOUR_CRYPTOBOT_TOKEN_HERE

# ZarinPal (Iranian Rial)
ZARINPAL_MERCHANT_ID=YOUR_ZARINPAL_MERCHANT_ID

# ============================================================================
# LOCALIZATION
# ============================================================================
DEFAULT_LANGUAGE=fa
SUPPORTED_LANGUAGES=fa,en,ar,ru,zh

# ============================================================================
# FILE STORAGE CONFIG
# ============================================================================
TEMP_DOWNLOAD_DIR=./temp_downloads
CACHE_FILE_DIR=./cached_files
MAX_FILE_SIZE=4294967296  # 4GB in bytes
MAX_FILE_AGE_HOURS=48

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_REFERRAL_SYSTEM=true
ENABLE_FORCE_JOIN=true
ENABLE_BROADCAST=true
ENABLE_ADMIN_PANEL=true

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/dlbot.log
LOG_FORMAT=json

# ============================================================================
# APP SETTINGS
# ============================================================================
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
WORKER_COUNT=4

# ============================================================================
# WEB PANEL (FastAPI)
# ============================================================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true
JWT_SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
