# ============================================================================
# TELEGRAM BOT CONFIG
# ============================================================================
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ADMIN_IDS=YOUR_ADMIN_USER_IDS_COMMA_SEPARATED
BOT_USERNAME=Max_youtube_downloader_bot

# ============================================================================
# DATABASE CONFIG
# ============================================================================
# برای شروع، SQLite استفاده می‌کنیم (بدون نیاز به سرور جداگانه)
DB_TYPE=sqlite
DB_PATH=./dlbot.db
DB_USER=dlbot_admin
DB_PASSWORD=YOUR_PASSWORD_VALUE
DB_NAME=dlbot_production

# ============================================================================
# REDIS CONFIG (اختیاری - برای شروع لازم نیست)
# ============================================================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=YOUR_PASSWORD_VALUE
# REDIS_DECODE_RESPONSES=true

# ============================================================================
# PYROGRAM CONFIG (for large file uploads up to 4GB)
# ============================================================================
PYROGRAM_APP_ID=YOUR_PYROGRAM_APP_ID
PYROGRAM_APP_HASH=YOUR_PYROGRAM_APP_HASH
PYROGRAM_SESSION_NAME=my_youtube_uploader

# ============================================================================
# CELERY CONFIG (اختیاری - برای شروع لازم نیست)
# ============================================================================
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
# CELERY_TASK_TIME_LIMIT=3600

# ============================================================================
# PAYMENT CONFIG
# ============================================================================
# CryptoBot (Telegram native crypto)
CRYPTOBOT_API_TOKEN=YOUR_CRYPTOBOT_API_TOKEN

# ZarinPal (Iranian Rial)
ZARINPAL_MERCHANT_ID=YOUR_ZARINPAL_MERCHANT_ID

# ============================================================================
# LOCALIZATION
# ============================================================================
DEFAULT_LANGUAGE=fa
SUPPORTED_LANGUAGES=fa,en,ar,ru,zh

# ============================================================================
# FILE STORAGE CONFIG
# ============================================================================
TEMP_DOWNLOAD_DIR=./temp_downloads
CACHE_FILE_DIR=./cached_files
MAX_FILE_SIZE=4294967296  # 4GB in bytes
MAX_FILE_AGE_HOURS=48

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_REFERRAL_SYSTEM=true
ENABLE_FORCE_JOIN=true
ENABLE_BROADCAST=true
ENABLE_ADMIN_PANEL=true

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/dlbot.log
LOG_FORMAT=json

# ============================================================================
# APP SETTINGS
# ============================================================================
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
WORKER_COUNT=2

# ============================================================================
# WEB PANEL (FastAPI)
# ============================================================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
